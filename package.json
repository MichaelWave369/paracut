{
  "name": "paracut",
  "version": "0.7.0",
  "private": true,
  "description": "ParaCut: local-first AI-assisted video editor where the timeline is a ledger.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "smoke:core": "tsx scripts/smoke-test.ts",
    "smoke:file": "tsx scripts/file-adapter-smoke-test.ts",
    "smoke:desktop": "tsx scripts/desktop-shell-smoke-test.ts",
    "smoke:runtime": "tsx scripts/desktop-runtime-smoke-test.ts",
    "smoke:ai": "tsx scripts/ai-approval-smoke-test.ts",
    "smoke": "pnpm smoke:core && pnpm smoke:file && pnpm smoke:desktop && pnpm smoke:runtime && pnpm smoke:ai",
    "test": "pnpm smoke",
    "dev:desktop": "pnpm --filter @paracut/desktop dev"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
